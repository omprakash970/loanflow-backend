    {
      "name": "Protected Endpoints",
      "item": [
        {
          "name": "Example: Protected Endpoint with Token",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://localhost:8080/api/protected",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "protected"]
            },
            "description": "Example of accessing protected endpoint with JWT token\n\nNote: Replace {{jwt_token}} with actual token from login response"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "jwt_token",
      "value": "paste_your_jwt_token_here",
      "type": "string"
    }
  ]
}

